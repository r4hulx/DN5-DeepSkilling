{
  "ReverseProxy": {
    "Routes": {
      "productRoute": {
        "ClusterId": "productCluster",
        "Match": {
          "Path": "/product/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/product"
          }
        ]
      },
      "orderRoute": {
        "ClusterId": "orderCluster",
        "Match": {
          "Path": "/order/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/order"
          }
        ]
      }
    },
    "Clusters": {
      "productCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5129/"
          }
        }
      },
      "orderCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5093/"
          }
        }
      }
    }
  }
}